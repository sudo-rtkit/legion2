# ─────────────────────────────────────────────────────────────
# LTD2 Coach — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Node environment
NODE_ENV=development

# ── Legion TD 2 Official API ─────────────────────────────────
# Request at: https://developer.legiontd2.com/
LTD2_API_KEY=your_api_key_here
LTD2_API_BASE_URL=https://apiv2.legiontd2.com

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=ltd2
POSTGRES_PASSWORD=ltd2_dev_password
POSTGRES_DB=ltd2_coach
POSTGRES_PORT=5432
DATABASE_URL=postgresql://neondb_owner:npg_oKe35MVETvIL@ep-jolly-dream-alz5ev0e-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Redis ────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── API server ───────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
API_LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# ── Web (Next.js) ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Observability (optional for local dev) ───────────────────
# POSTHOG_KEY=
# POSTHOG_HOST=
# SENTRY_DSN=
