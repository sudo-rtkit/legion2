{
  "name": "@ltd2-coach/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=../../.env src/db/migrate.ts",
    "sync:data": "tsx --env-file=../../.env src/sync/sync.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist drizzle"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.0",
    "@ltd2-coach/ltd2-client": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.0.0",
    "postgres": "^3.4.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
