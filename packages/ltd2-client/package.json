{
  "name": "@ltd2-coach/ltd2-client",
  "version": "0.1.0",
  "description": "Typed client for the official Legion TD 2 API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage .tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.0.0"
  }
}
